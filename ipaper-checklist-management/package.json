{
  "name": "ipaper-checklist-management",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx",
    "lint:fix": "eslint . --fix --ext .js,.mjs,.cjs,.ts,.tsx",
    "seed:generate": "node scripts/seed/index.mjs --dry-run",
    "seed:generate:full": "node scripts/seed/index.mjs --dry-run --from 2025-01-01 --to 2025-12-31",
    "seed:ingest": "node scripts/seed/ingest.mjs --run latest",
    "seed:ingest:dry": "node scripts/seed/ingest.mjs --run latest --dry-run",
    "seed:ingest:assets": "node scripts/seed/ingest.mjs --run latest --only assets",
    "seed:ingest:apm-schema": "node scripts/seed/ingest.mjs --run latest --only apm-schema",
    "seed:ingest:apm-checklists": "node scripts/seed/ingest.mjs --run latest --only apm-checklists",
    "seed:ingest:ip-schema": "node scripts/seed/ingest.mjs --run latest --only ip-schema",
    "seed:ingest:kpis": "node scripts/seed/ingest.mjs --run latest --only kpis",
    "seed:clean": "node scripts/seed/clean.mjs",
    "seed:clean:dry": "node scripts/seed/clean.mjs --dry-run",
    "seed:clean:ip": "node scripts/seed/clean.mjs --only ip",
    "seed:clean:ip:dry": "node scripts/seed/clean.mjs --only ip --dry-run",
    "seed:clean:kpis": "node scripts/seed/clean.mjs --only kpis",
    "seed:clean:assets": "node scripts/seed/clean.mjs --space flows_radix_space_group1",
    "seed:clean:checklist": "node scripts/seed/clean.mjs --space flows_radix_checklist_group1",
    "deploy": "npx @cognite/cli@latest apps deploy --interactive",
    "activate": "npx @cognite/cli@latest apps activate --interactive",
    "setup-https": "npx @cognite/cli@latest apps setup-https",
    "spec:check": "node scripts/spec-check.mjs",
    "spec:check:strict": "node scripts/spec-check.mjs --strict",
    "spec:new": "node scripts/spec-new.mjs",
    "mcp:cdf": "node scripts/cdf-mcp/server.mjs"
  },
  "dependencies": {
    "@cognite/app-sdk": "^0.5.1",
    "@cognite/aura": "^0.1.7",
    "@cognite/sdk": "^10.3.0",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.90.10",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.22",
    "eslint": "9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.46.4",
    "vite": "7.3.2",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  }
}
