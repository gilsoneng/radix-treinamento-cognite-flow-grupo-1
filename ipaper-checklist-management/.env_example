# MCP cognite-cdf (Cursor): uses the same variables via scripts/cdf-mcp — fill IDP_CLIENT_ID/SECRET in .env
CDF_CLUSTER=az-eastus-1
CDF_PROJECT=radix-dev
LOGIN_FLOW=client_credentials
IDP_CLIENT_ID=
IDP_CLIENT_SECRET=
# Note: Either the TENANT_ID or the TENANT_URL must be written.
IDP_TENANT_ID=9339fb1c-0944-4fb9-808d-a278e53590e5
IDP_TOKEN_URL=https://login.microsoftonline.com/9339fb1c-0944-4fb9-808d-a278e53590e5/oauth2/v2.0/token
# The below variables are the defaults, they are automatically constructed unless they are set.
CDF_URL=https://az-eastus-1.cognitedata.com
IDP_SCOPES=https://az-eastus-1.cognitedata.com/.default
IDP_AUDIENCE=https://az-eastus-1.cognitedata.com